{
  "name": "chatcrystal",
  "version": "0.1.0",
  "private": true,
  "description": "AI conversation knowledge crystallization tool",
  "main": "electron/dist/main.js",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w server && npm run build -w client",
    "start": "npm run start -w server",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "tray": "powershell -ExecutionPolicy Bypass -File scripts/tray.ps1",
    "tray:silent": "wscript scripts\\start-silent.vbs",
    "dev:electron": "tsc -p electron/tsconfig.json && concurrently \"npm run dev:server\" \"npm run dev:client\" \"wait-on http://localhost:13721 && cross-env VITE_DEV_URL=http://localhost:13721 electron .\"",
    "build:electron": "npm run build && tsc -p electron/tsconfig.json && electron-builder --win",
    "pack:electron": "npm run build && tsc -p electron/tsconfig.json && electron-builder --win --dir"
  },
  "author": "Rayner Zeng",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/azure": "^3.0.49",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai": "^3.0.48",
    "@fastify/cors": "^11.0.0",
    "@fastify/static": "^8.1.0",
    "ai": "^6.0.140",
    "chokidar": "^4.0.3",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",

    "p-queue": "^8.1.0",
    "sql.js": "^1.12.0",
    "vectra": "^0.9.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.4"
  }
}
